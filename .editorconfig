# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonl}]
indent_size = 2

[*.toml]
indent_size = 4

[*.md]
# Trailing whitespace is significant in Markdown (line break = two spaces)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
