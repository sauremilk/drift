{
  "version": "2.10.0",
  "feature": "drift verify subcommand (ADR-070)",
  "date": "2026-04-14",
  "adr": "docs/decisions/ADR-070-verify-subcommand.md",
  "summary": "Binary pass/fail coherence gate wrapping shadow_verify() with a severity-threshold gate. Returns structured pass/fail verdict, blocking_reasons, score_delta, and direction. Available as CLI subcommand and drift_verify MCP tool.",
  "design_goals": [
    "Single yes/no verdict suitable for CI exit codes",
    "Configurable severity threshold via --fail-on",
    "File-scoped verification via --scope-files",
    "Consistent response shape with ADR-024 next-step contract",
    "MCP tool parity alongside CLI"
  ],
  "non_goals": [
    "No new signal detection",
    "No scoring model changes",
    "shadow_verify() internals unchanged"
  ],
  "test_coverage": {
    "test_file": "tests/test_verify.py",
    "total_tests": 41,
    "passed": 41,
    "failed": 0,
    "coverage_areas": [
      "CLI invocation with default options",
      "CLI --fail-on threshold (critical/high/medium/low)",
      "CLI --format json output structure",
      "CLI exit codes (0=pass, 1=fail)",
      "CLI --scope-files filtering",
      "API verify() return schema",
      "API blocking_reasons structure",
      "API score_delta and direction fields",
      "API agent_instruction field",
      "API next_tool_call ADR-024 contract",
      "MCP tool drift_verify registration",
      "MCP tool drift_verify in _EXPORTED_MCP_TOOLS"
    ]
  },
  "mcp_tool_registration": {
    "tool_name": "drift_verify",
    "registered_in_exported_tools": true,
    "function_location": "src/drift/mcp_server.py"
  },
  "cli_command": {
    "command": "drift verify",
    "options": [
      "--repo",
      "--fail-on",
      "--scope-files",
      "--uncommitted",
      "--staged-only",
      "--format"
    ],
    "exit_codes": {
      "0": "Coherence check passed",
      "1": "Findings above threshold detected",
      "2": "Configuration or usage error"
    }
  },
  "api_surface": {
    "module": "drift.api.verify",
    "function": "verify()",
    "response_fields": [
      "pass",
      "blocking_reasons",
      "findings_introduced",
      "findings_resolved",
      "score_before",
      "score_after",
      "score_delta",
      "direction",
      "agent_instruction",
      "next_tool_call"
    ]
  },
  "full_suite_regression": {
    "run_date": "2026-04-14",
    "passed": 4674,
    "skipped": 126,
    "failed": 0,
    "baseline_version": "2.9.15"
  },
  "precision_recall_unchanged": true,
  "signal_weights_unchanged": true,
  "audit_artifacts_affected": false,
  "notes": "drift verify wraps shadow_verify() — no new signal logic, no scoring changes. Pre-existing drift_shadow_verify MCP tool is now deprecated in favour of drift_verify (ADR-070)."
}
