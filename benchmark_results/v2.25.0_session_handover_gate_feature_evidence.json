{
  "version": "2.25.0",
  "feature": "session_handover_gate",
  "adr": "ADR-079",
  "description": "Hard-gate at drift_session_end that enforces authored handover artifacts: versioned evidence JSON + ADR draft + work_artifacts/session_<id>.md with semantic checks (existence, shape, placeholder denylist, optional L4 LLM review).",
  "change_classes": {
    "signal": ["evidence", "adr", "session_md"],
    "architecture": ["evidence", "adr", "session_md"],
    "fix": ["session_md"],
    "docs": ["session_md"],
    "chore": ["session_md"]
  },
  "layers": {
    "L1": "existence + minimum size (200 B Markdown, 64 B JSON)",
    "L2": "frontmatter + 5 required sections + session_id cross-check; evidence JSON key schema; ADR status/Kontext/Alternativen/Entscheidung/Konsequenzen",
    "L3": "placeholder denylist (TODO, FIXME, XXX, TBD, ???, <N>, <NNN>, LOREM, IPSUM, FOO, BAR, BAZ) with ≥5-line code-fence exemption",
    "L4": "opt-in LLM review via DRIFT_SESSION_END_LLM_REVIEW=1 or llm_reviewer kwarg; fails closed on exception"
  },
  "error_codes": {
    "DRIFT-6100": "Handover artifacts missing/invalid; session remains alive for retry",
    "DRIFT-6101": "force=true with invalid or placeholder bypass_reason"
  },
  "bypass_policy": {
    "force_param": true,
    "min_reason_chars": 40,
    "placeholder_denylist_applied": true,
    "audit": "WARNING log on 'drift' logger + session.record_trace(advisory='session_handover.blocked')",
    "bounded_retries": 5
  },
  "tests": {
    "unit_tests": {
      "file": "tests/test_session_handover.py",
      "count": 25,
      "classes": [
        "TestClassifyTouched",
        "TestRequiredArtifacts",
        "TestL1Existence",
        "TestL2Shape",
        "TestL3Placeholders",
        "TestValidationResult"
      ]
    },
    "integration_tests": {
      "file": "tests/test_session_end_gate.py",
      "count": 7,
      "scenarios": [
        "blocks_when_artifacts_missing",
        "unblocks_when_all_artifacts_valid",
        "force_requires_valid_bypass_reason",
        "force_with_placeholder_reason_blocks",
        "force_with_valid_reason_unblocks",
        "retry_counter_increments_on_each_block",
        "empty_session_without_work_is_exempt"
      ]
    },
    "llm_hook_tests": {
      "file": "tests/test_session_handover_llm.py",
      "count": 6,
      "scenarios": [
        "semantic_ok_absent_when_disabled",
        "semantic_ok_true_when_reviewer_accepts",
        "semantic_ok_false_blocks",
        "reviewer_exception_fails_closed",
        "reviewer_skipped_when_earlier_layer_blocked",
        "env_flag_enables_reviewer"
      ]
    }
  },
  "audit_artifacts_updated": [
    "audit_results/fmea_matrix.md",
    "audit_results/risk_register.md",
    "audit_results/fault_trees.md"
  ],
  "files_added": [
    "src/drift/session_handover.py",
    "tests/test_session_handover.py",
    "tests/test_session_end_gate.py",
    "tests/test_session_handover_llm.py",
    "docs/decisions/ADR-079-session-handover-artifact-gate.md",
    "docs/session_handover_template.md",
    ".github/prompts/_partials/session-handover-contract.md",
    ".github/skills/drift-session-handover-authoring/SKILL.md",
    "benchmark_results/v2.25.0_session_handover_gate_feature_evidence.json"
  ],
  "files_changed": [
    "src/drift/session.py",
    "src/drift/mcp_router_session.py",
    "src/drift/mcp_server.py",
    "CHANGELOG.md"
  ],
  "empty_session_exemption": {
    "conditions_all_required": [
      "session.completed_task_ids is empty",
      "session.selected_tasks is empty/None",
      "session.tool_calls < 3",
      "classify_session(session) == CHORE"
    ],
    "rationale": "Preserves backward compatibility for read-only explorations and prevents Security-Theater from agents calling session_end with zero work."
  }
}
