  "features": [
    {
      "id": "dia-codespan-context-gate",
      "cut_set": "CS-1",
      "description": "Codespan tokens now require sibling-text structure-keyword context instead of unconditional extraction. Prevents false positives from inline code in non-structural Markdown paragraphs.",
      "tests": [
        "tests/test_dia_enhanced.py::TestCodespanContextGate::test_backtick_without_keyword_suppressed",
        "tests/test_dia_enhanced.py::TestCodespanContextGate::test_backtick_with_keyword_extracted",
        "tests/test_dia_enhanced.py::TestCodespanContextGate::test_standalone_codespan_outside_paragraph",
        "tests/test_dia_enhanced.py::TestContextPropagationAcrossSiblings::test_heading_context_propagates_to_list",
        "tests/test_dia_enhanced.py::TestContextPropagationAcrossSiblings::test_context_from_architecture_section"
      ]
    },
    {
      "id": "dia-container-prefix-existence",
      "cut_set": "CS-2",
      "description": "Directory existence checks now resolve paths under common container prefixes (src/, lib/, app/, pkg/, packages/, libs/, internal/) before reporting missing directories.",
      "tests": [
        "tests/test_dia_enhanced.py::TestContainerPrefixExistence::test_src_prefix_resolves",
        "tests/test_dia_enhanced.py::TestContainerPrefixExistence::test_app_prefix_resolves",
        "tests/test_dia_enhanced.py::TestContainerPrefixExistence::test_non_container_prefix_not_resolved"
      ]
    },
    {
      "id": "dia-adr-status-filtering",
      "cut_set": "CS-3",
      "description": "ADR files with status superseded, deprecated, or rejected are skipped during scanning. Supports both YAML frontmatter and MADR freetext format.",
      "tests": [
        "tests/test_dia_enhanced.py::TestAdrStatusFiltering::test_superseded_adr_skipped",
        "tests/test_dia_enhanced.py::TestAdrStatusFiltering::test_accepted_adr_scanned",
        "tests/test_dia_enhanced.py::TestAdrStatusFiltering::test_no_status_adr_scanned",
        "tests/test_dia_enhanced.py::TestAdrStatusFiltering::test_madr_freetext_status"
      ]
    }
  ],
