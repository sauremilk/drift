{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://drift-analyzer.dev/schemas/output/v2.1",
  "title": "Drift Analysis Output",
  "description": "JSON output schema for 'drift analyze --format json' (v2.1). Major version = breaking changes, minor version = additive fields.",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "repo",
    "analyzed_at",
    "drift_score",
    "severity"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.1",
      "description": "Output format version (semver-like: major.minor)."
    },
    "version": {
      "type": "string",
      "description": "Drift application version."
    },
    "signal_abbrev_map": {
      "type": "object",
      "description": "Mapping of signal abbreviations to canonical signal type names.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "repo": {
      "type": "string"
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time"
    },
    "drift_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "grade": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "F"],
      "description": "Letter grade derived from drift_score (A=best, F=worst)."
    },
    "grade_label": {
      "type": "string",
      "description": "Human-readable label for the grade, e.g. 'Good' or 'Critical Drift'."
    },
    "drift_score_scope": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "analysis_status": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "degraded": {
          "type": "boolean"
        },
        "is_fully_reliable": {
          "type": "boolean"
        },
        "causes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected_components": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "events": {
          "type": "array"
        }
      }
    },
    "trend": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "previous_score": {
          "type": [
            "number",
            "null"
          ]
        },
        "delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "direction": {
          "type": "string"
        },
        "recent_scores": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "history_depth": {
          "type": "integer"
        },
        "transition_ratio": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_files": {
          "type": "integer"
        },
        "total_functions": {
          "type": "integer"
        },
        "ai_attributed_ratio": {
          "type": "number"
        },
        "ai_tools_detected": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "analysis_duration_seconds": {
          "type": [
            "number",
            "null"
          ]
        },
        "phase_timing": {
          "type": "object",
          "description": "Duration in seconds for each analysis phase.",
          "properties": {
            "discover_seconds": {
              "type": "number"
            },
            "parse_seconds": {
              "type": "number"
            },
            "git_seconds": {
              "type": "number"
            },
            "signals_seconds": {
              "type": "number"
            },
            "output_seconds": {
              "type": "number"
            },
            "total_seconds": {
              "type": "number"
            }
          }
        },
        "skipped_languages": {
          "type": ["object", "null"],
          "description": "Languages skipped due to missing runtime (e.g. tree-sitter). Keys are language names, values are file counts.",
          "additionalProperties": {
            "type": "integer"
          }
        }
      }
    },
    "findings_compact": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rank",
          "finding_id",
          "signal",
          "severity",
          "title"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "finding_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{16}$",
            "description": "Deterministic content-based fingerprint (SHA256 prefix)."
          },
          "signal": {
            "type": "string"
          },
          "signal_abbrev": {
            "type": "string"
          },
          "rule_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suppressed",
              "resolved"
            ]
          },
          "finding_context": {
            "type": "string"
          },
          "impact": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "score_contribution": {
            "type": "number"
          },
          "title": {
            "type": "string"
          },
          "file": {
            "type": [
              "string",
              "null"
            ]
          },
          "language": {
            "type": ["string", "null"],
            "description": "Source language of the file (e.g. python, typescript).",
            "enum": ["python", "typescript", "tsx", "javascript", "jsx", null]
          },
          "start_line": {
            "type": [
              "integer",
              "null"
            ]
          },
          "duplicate_count": {
            "type": "integer",
            "minimum": 1
          },
          "next_step": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "description": "Ranked findings in compact form for quick prioritization."
    },
    "compact_summary": {
      "type": "object",
      "properties": {
        "findings_total": {
          "type": "integer"
        },
        "findings_deduplicated": {
          "type": "integer"
        },
        "duplicate_findings_removed": {
          "type": "integer"
        },
        "suppressed_total": {
          "type": "integer"
        },
        "critical_count": {
          "type": "integer"
        },
        "high_count": {
          "type": "integer"
        },
        "fix_first_count": {
          "type": "integer"
        }
      }
    },
    "fix_first": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rank",
          "finding_id",
          "signal",
          "severity",
          "title"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "finding_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{16}$"
          },
          "priority_class": {
            "type": "string"
          },
          "signal": {
            "type": "string"
          },
          "signal_abbrev": {
            "type": "string"
          },
          "rule_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "finding_context": {
            "type": "string"
          },
          "impact": {
            "type": "number"
          },
          "score_contribution": {
            "type": "number"
          },
          "title": {
            "type": "string"
          },
          "file": {
            "type": [
              "string",
              "null"
            ]
          },
          "language": {
            "type": ["string", "null"],
            "description": "Source language of the file (e.g. python, typescript).",
            "enum": ["python", "typescript", "tsx", "javascript", "jsx", null]
          },
          "start_line": {
            "type": [
              "integer",
              "null"
            ]
          },
          "next_step": {
            "type": [
              "string",
              "null"
            ]
          },
          "expected_benefit": {
            "type": "string"
          }
        }
      },
      "description": "Top prioritized findings for immediate action."
    },
    "finding_context_policy": {
      "type": "object"
    },
    "suppressed_count": {
      "type": "integer"
    },
    "context_tagged_count": {
      "type": "integer"
    },
    "baseline": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "new_findings_count": {
          "type": [
            "integer",
            "null"
          ]
        },
        "baseline_matched_count": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "negative_context": {
      "type": "array"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "drift_score": {
            "type": "number"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "signal_scores": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          "finding_count": {
            "type": "integer"
          },
          "ai_ratio": {
            "type": "number"
          }
        }
      },
      "description": "Per-module drift scores (omitted in compact mode)."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "signal",
          "severity",
          "title"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{16}$",
            "description": "Deterministic content-based fingerprint (SHA256 prefix)."
          },
          "signal": {
            "type": "string"
          },
          "signal_abbrev": {
            "type": "string"
          },
          "rule_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "impact": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "score_contribution": {
            "type": "number"
          },
          "impact_rank": {
            "type": [
              "integer",
              "null"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "fix": {
            "type": [
              "string",
              "null"
            ]
          },
          "file": {
            "type": [
              "string",
              "null"
            ]
          },
          "language": {
            "type": ["string", "null"],
            "description": "Source language of the file (e.g. python, typescript).",
            "enum": ["python", "typescript", "tsx", "javascript", "jsx", null]
          },
          "start_line": {
            "type": [
              "integer",
              "null"
            ]
          },
          "end_line": {
            "type": [
              "integer",
              "null"
            ]
          },
          "finding_context": {
            "type": "string"
          },
          "symbol": {
            "type": [
              "string",
              "null"
            ]
          },
          "logical_location": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "fully_qualified_name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "kind": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "class_name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "namespace": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "related_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ai_attributed": {
            "type": "boolean"
          },
          "deferred": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suppressed",
              "resolved"
            ]
          },
          "status_set_by": {
            "type": [
              "string",
              "null"
            ]
          },
          "status_reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "metadata": {
            "type": "object"
          },
          "attribution": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "commit_hash": {
                "type": "string"
              },
              "author": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "format": "date"
              },
              "branch_hint": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "ai_attributed": {
                "type": "boolean"
              },
              "ai_confidence": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "commit_message": {
                "type": "string"
              }
            }
          },
          "remediation": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "effort": {
                "type": "string"
              },
              "impact": {
                "type": "string"
              }
            }
          }
        }
      },
      "description": "Full finding details (omitted in compact mode)."
    },
    "findings_suppressed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "signal",
          "severity",
          "title"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
