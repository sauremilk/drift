{
  "$defs": {
    "AgentEffectivenessThresholds": {
      "additionalProperties": false,
      "description": "Thresholds for deterministic low-effect/high-churn warnings.",
      "properties": {
        "low_effect_resolved_per_changed_file": {
          "default": 0.25,
          "title": "Low Effect Resolved Per Changed File",
          "type": "number"
        },
        "low_effect_resolved_per_100_loc_changed": {
          "default": 0.5,
          "title": "Low Effect Resolved Per 100 Loc Changed",
          "type": "number"
        },
        "high_churn_min_changed_files": {
          "default": 5,
          "title": "High Churn Min Changed Files",
          "type": "integer"
        },
        "high_churn_min_loc_changed": {
          "default": 200,
          "title": "High Churn Min Loc Changed",
          "type": "integer"
        }
      },
      "title": "AgentEffectivenessThresholds",
      "type": "object"
    },
    "AgentObjective": {
      "additionalProperties": false,
      "description": "Declarative agent objective for drift.yaml.\n\nAllows agents to declare their goal, out-of-scope areas,\nand success criteria so drift can provide targeted feedback.\n\nExample drift.yaml::\n\n    agent:\n      goal: \"Migrate payment module to Stripe API\"\n      out_of_scope:\n        - \"legacy/\"\n        - \"tests/fixtures/\"\n      success_criteria:\n        - \"No new AVS findings in src/billing/\"",
      "properties": {
        "goal": {
          "default": "",
          "description": "Natural-language description of the agent's current task.",
          "title": "Goal",
          "type": "string"
        },
        "strict_guardrails": {
          "default": false,
          "description": "When true, MCP orchestration enforces strict preconditions and blocks unsafe tool transitions with recovery hints.",
          "title": "Strict Guardrails",
          "type": "boolean"
        },
        "out_of_scope": {
          "description": "Glob patterns or paths the agent should not modify or analyze.",
          "items": {
            "type": "string"
          },
          "title": "Out Of Scope",
          "type": "array"
        },
        "success_criteria": {
          "description": "Conditions that define task completion (human-readable).",
          "items": {
            "type": "string"
          },
          "title": "Success Criteria",
          "type": "array"
        },
        "effectiveness_thresholds": {
          "$ref": "#/$defs/AgentEffectivenessThresholds",
          "description": "Thresholds used for deterministic effectiveness warnings (e.g. low_effect_high_churn)."
        }
      },
      "title": "AgentObjective",
      "type": "object"
    },
    "AttributionConfig": {
      "additionalProperties": false,
      "description": "Configuration for causal attribution enrichment (ADR-034).\n\nWhen enabled, findings are enriched with git-blame provenance data\nidentifying the commit, author, and date that introduced the drifting code.\n\nExample drift.yaml::\n\n    attribution:\n      enabled: true\n      timeout_per_file_seconds: 3.0",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable git-blame-based causal attribution on findings.",
          "title": "Enabled",
          "type": "boolean"
        },
        "cache_enabled": {
          "default": true,
          "description": "Cache blame results per file content hash.",
          "title": "Cache Enabled",
          "type": "boolean"
        },
        "timeout_per_file_seconds": {
          "default": 3.0,
          "description": "Maximum seconds for a single git-blame subprocess call.",
          "title": "Timeout Per File Seconds",
          "type": "number"
        },
        "max_parallel_workers": {
          "default": 4,
          "description": "Thread pool size for parallel blame calls.",
          "title": "Max Parallel Workers",
          "type": "integer"
        },
        "include_branch_hint": {
          "default": true,
          "description": "Attempt to extract branch name from merge-commit messages.",
          "title": "Include Branch Hint",
          "type": "boolean"
        }
      },
      "title": "AttributionConfig",
      "type": "object"
    },
    "BriefConfig": {
      "additionalProperties": false,
      "description": "Configuration for ``drift brief`` pre-task briefings.",
      "properties": {
        "scope_aliases": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Keyword → path mapping for scope resolution. Example: {payment: src/billing/, auth: src/auth/}",
          "title": "Scope Aliases",
          "type": "object"
        }
      },
      "title": "BriefConfig",
      "type": "object"
    },
    "CalibrationConfig": {
      "additionalProperties": false,
      "description": "Configuration for per-repo signal calibration (ADR-035).\n\nWhen enabled, drift collects and uses feedback evidence to compute\nproject-specific signal weights via Bayesian weight calibration.\n\nExample drift.yaml::\n\n    calibration:\n      enabled: true\n      min_samples: 20\n      bug_labels:\n        - bug\n        - regression",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable per-repo signal calibration.",
          "title": "Enabled",
          "type": "boolean"
        },
        "min_samples": {
          "default": 20,
          "description": "Minimum TP+FP observations per signal for full confidence. Below this, calibration blends toward default weights.",
          "title": "Min Samples",
          "type": "integer"
        },
        "correlation_window_days": {
          "default": 30,
          "description": "Days after a scan to look for defect-fix commits (TP evidence).",
          "title": "Correlation Window Days",
          "type": "integer"
        },
        "decay_days": {
          "default": 90,
          "description": "Days after which the calibration profile is considered stale.",
          "title": "Decay Days",
          "type": "integer"
        },
        "weak_fp_window_days": {
          "default": 60,
          "description": "Days without a defect-fix → weak FP evidence.",
          "title": "Weak Fp Window Days",
          "type": "integer"
        },
        "fn_boost_factor": {
          "default": 0.1,
          "description": "How much to boost weight for signals with high false-negative rate (0.0 disables FN boosting, max 1.0).",
          "title": "Fn Boost Factor",
          "type": "number"
        },
        "github_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub API token for issue/PR correlation (or use DRIFT_GITHUB_TOKEN env).",
          "title": "Github Token"
        },
        "bug_labels": {
          "description": "Issue labels that identify bug reports for GitHub correlation.",
          "items": {
            "type": "string"
          },
          "title": "Bug Labels",
          "type": "array"
        },
        "auto_recalibrate": {
          "default": false,
          "description": "Automatically recalibrate after each drift analyze run.",
          "title": "Auto Recalibrate",
          "type": "boolean"
        },
        "feedback_path": {
          "default": ".drift/feedback.jsonl",
          "description": "Path to the feedback JSONL file (relative to repo root).",
          "title": "Feedback Path",
          "type": "string"
        },
        "history_dir": {
          "default": ".drift/history",
          "description": "Directory for scan history snapshots (relative to repo root).",
          "title": "History Dir",
          "type": "string"
        },
        "max_snapshots": {
          "default": 20,
          "description": "Maximum number of scan snapshots to retain.",
          "title": "Max Snapshots",
          "type": "integer"
        },
        "threshold_adaptation_enabled": {
          "default": false,
          "description": "Enable adaptive threshold adjustment per signal based on feedback metrics.  Experimental — disabled by default.",
          "title": "Threshold Adaptation Enabled",
          "type": "boolean"
        }
      },
      "title": "CalibrationConfig",
      "type": "object"
    },
    "DeferredArea": {
      "additionalProperties": false,
      "description": "A glob-matched area marked as known technical debt (not excluded).\n\nUnlike ``exclude``, deferred areas are still analysed.  Findings in\ndeferred areas are tagged ``deferred=True`` so CI gates and reports\ncan treat them differently.",
      "properties": {
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "reason": {
          "default": "",
          "title": "Reason",
          "type": "string"
        },
        "review_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review By"
        }
      },
      "required": [
        "pattern"
      ],
      "title": "DeferredArea",
      "type": "object"
    },
    "DocImplDriftConfig": {
      "additionalProperties": false,
      "description": "DIA-specific configuration for doc-implementation drift detection.",
      "properties": {
        "extra_auxiliary_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Extra Auxiliary Dirs",
          "type": "array"
        },
        "extra_context_keywords": {
          "items": {
            "type": "string"
          },
          "title": "Extra Context Keywords",
          "type": "array"
        }
      },
      "title": "DocImplDriftConfig",
      "type": "object"
    },
    "FindingContextPolicy": {
      "additionalProperties": false,
      "description": "Policy for finding-context classification and triage behavior.",
      "properties": {
        "rules": {
          "items": {
            "$ref": "#/$defs/FindingContextRule"
          },
          "title": "Rules",
          "type": "array"
        },
        "non_operational_contexts": {
          "items": {
            "type": "string"
          },
          "title": "Non Operational Contexts",
          "type": "array"
        },
        "default_context": {
          "default": "production",
          "title": "Default Context",
          "type": "string"
        }
      },
      "title": "FindingContextPolicy",
      "type": "object"
    },
    "FindingContextRule": {
      "additionalProperties": false,
      "description": "Classify findings by file path using glob patterns.",
      "properties": {
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "context": {
          "title": "Context",
          "type": "string"
        },
        "precedence": {
          "default": 0,
          "title": "Precedence",
          "type": "integer"
        }
      },
      "required": [
        "pattern",
        "context"
      ],
      "title": "FindingContextRule",
      "type": "object"
    },
    "LanguagesConfig": {
      "additionalProperties": false,
      "description": "Per-language scanning settings (drift.yaml → ``languages:``).",
      "properties": {
        "typescript": {
          "default": true,
          "description": "Enable TypeScript/TSX/JS/JSX analysis. Requires drift-analyzer[typescript] (tree-sitter). Set to false to skip TS files even when tree-sitter is installed.",
          "title": "Typescript",
          "type": "boolean"
        }
      },
      "title": "LanguagesConfig",
      "type": "object"
    },
    "LayerBoundary": {
      "additionalProperties": false,
      "description": "A single layer boundary rule.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "from": {
          "title": "From",
          "type": "string"
        },
        "deny_import": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Deny Import",
          "type": "array"
        }
      },
      "required": [
        "name",
        "from"
      ],
      "title": "LayerBoundary",
      "type": "object"
    },
    "LazyImportRule": {
      "additionalProperties": false,
      "description": "Policy rule for enforcing lazy imports of selected modules.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "from": {
          "title": "From",
          "type": "string"
        },
        "modules": {
          "items": {
            "type": "string"
          },
          "title": "Modules",
          "type": "array"
        },
        "module_level_only": {
          "default": true,
          "title": "Module Level Only",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "from"
      ],
      "title": "LazyImportRule",
      "type": "object"
    },
    "PathOverride": {
      "additionalProperties": false,
      "description": "Per-path configuration overrides.\n\nMatch paths using glob patterns (e.g. ``tests/**``, ``legacy/``).\nMore specific patterns take precedence over broader ones.",
      "properties": {
        "weights": {
          "anyOf": [
            {
              "$ref": "#/$defs/SignalWeights"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "exclude_signals": {
          "items": {
            "type": "string"
          },
          "title": "Exclude Signals",
          "type": "array"
        },
        "severity_gate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Severity Gate"
        }
      },
      "title": "PathOverride",
      "type": "object"
    },
    "PluginConfig": {
      "additionalProperties": false,
      "description": "Configuration for Drift plugins.\n\nPlugins are discovered via Python entry_points (see drift.plugins).\nThis configuration section allows selectively disabling specific plugins.\n\nExample drift.yaml::\n\n    plugins:\n      disabled:\n        - my_broken_plugin",
      "properties": {
        "disabled": {
          "description": "List of plugin entry-point names to skip at discovery time.",
          "items": {
            "type": "string"
          },
          "title": "Disabled",
          "type": "array"
        }
      },
      "title": "PluginConfig",
      "type": "object"
    },
    "PolicyConfig": {
      "additionalProperties": false,
      "description": "Policy configuration for enforcement rules.",
      "properties": {
        "error_handling": {
          "additionalProperties": true,
          "title": "Error Handling",
          "type": "object"
        },
        "layer_boundaries": {
          "items": {
            "$ref": "#/$defs/LayerBoundary"
          },
          "title": "Layer Boundaries",
          "type": "array"
        },
        "max_pattern_variants": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Max Pattern Variants",
          "type": "object"
        },
        "ai_attribution": {
          "additionalProperties": true,
          "title": "Ai Attribution",
          "type": "object"
        },
        "allowed_cross_layer": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Cross Layer",
          "type": "array"
        },
        "lazy_import_rules": {
          "items": {
            "$ref": "#/$defs/LazyImportRule"
          },
          "title": "Lazy Import Rules",
          "type": "array"
        },
        "omnilayer_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Omnilayer Dirs",
          "type": "array"
        }
      },
      "title": "PolicyConfig",
      "type": "object"
    },
    "SignalWeights": {
      "additionalProperties": true,
      "description": "Weights for each detection signal in composite scoring.\n\nWeights are normalised internally — they don't need to sum to 1.0,\nbut a warning is emitted if they deviate significantly.\n\nSignals can be run in report-only mode by assigning weight 0.0.\nThis keeps detection visible while removing score impact until\nprecision/recall is sufficiently validated.",
      "properties": {
        "pattern_fragmentation": {
          "default": 0.16,
          "title": "Pattern Fragmentation",
          "type": "number"
        },
        "architecture_violation": {
          "default": 0.16,
          "title": "Architecture Violation",
          "type": "number"
        },
        "mutant_duplicate": {
          "default": 0.13,
          "title": "Mutant Duplicate",
          "type": "number"
        },
        "explainability_deficit": {
          "default": 0.09,
          "title": "Explainability Deficit",
          "type": "number"
        },
        "temporal_volatility": {
          "default": 0.0,
          "title": "Temporal Volatility",
          "type": "number"
        },
        "system_misalignment": {
          "default": 0.08,
          "title": "System Misalignment",
          "type": "number"
        },
        "doc_impl_drift": {
          "default": 0.04,
          "title": "Doc Impl Drift",
          "type": "number"
        },
        "broad_exception_monoculture": {
          "default": 0.04,
          "title": "Broad Exception Monoculture",
          "type": "number"
        },
        "test_polarity_deficit": {
          "default": 0.04,
          "title": "Test Polarity Deficit",
          "type": "number"
        },
        "guard_clause_deficit": {
          "default": 0.03,
          "title": "Guard Clause Deficit",
          "type": "number"
        },
        "cohesion_deficit": {
          "default": 0.01,
          "title": "Cohesion Deficit",
          "type": "number"
        },
        "naming_contract_violation": {
          "default": 0.04,
          "title": "Naming Contract Violation",
          "type": "number"
        },
        "bypass_accumulation": {
          "default": 0.03,
          "title": "Bypass Accumulation",
          "type": "number"
        },
        "exception_contract_drift": {
          "default": 0.03,
          "title": "Exception Contract Drift",
          "type": "number"
        },
        "co_change_coupling": {
          "default": 0.005,
          "title": "Co Change Coupling",
          "type": "number"
        },
        "ts_architecture": {
          "default": 0.0,
          "title": "Ts Architecture",
          "type": "number"
        },
        "cognitive_complexity": {
          "default": 0.0,
          "title": "Cognitive Complexity",
          "type": "number"
        },
        "circular_import": {
          "default": 0.0,
          "title": "Circular Import",
          "type": "number"
        },
        "dead_code_accumulation": {
          "default": 0.0,
          "title": "Dead Code Accumulation",
          "type": "number"
        },
        "fan_out_explosion": {
          "default": 0.005,
          "title": "Fan Out Explosion",
          "type": "number"
        },
        "hardcoded_secret": {
          "default": 0.01,
          "title": "Hardcoded Secret",
          "type": "number"
        },
        "phantom_reference": {
          "default": 0.02,
          "title": "Phantom Reference",
          "type": "number"
        },
        "missing_authorization": {
          "default": 0.02,
          "title": "Missing Authorization",
          "type": "number"
        },
        "insecure_default": {
          "default": 0.01,
          "title": "Insecure Default",
          "type": "number"
        }
      },
      "title": "SignalWeights",
      "type": "object"
    },
    "ThresholdsConfig": {
      "additionalProperties": false,
      "description": "Tunable thresholds for detection signals.",
      "properties": {
        "high_complexity": {
          "default": 10,
          "title": "High Complexity",
          "type": "integer"
        },
        "medium_complexity": {
          "default": 5,
          "title": "Medium Complexity",
          "type": "integer"
        },
        "min_function_loc": {
          "default": 15,
          "title": "Min Function Loc",
          "type": "integer"
        },
        "min_complexity": {
          "default": 8,
          "title": "Min Complexity",
          "type": "integer"
        },
        "similarity_threshold": {
          "default": 0.8,
          "title": "Similarity Threshold",
          "type": "number"
        },
        "recency_days": {
          "default": 14,
          "title": "Recency Days",
          "type": "integer"
        },
        "volatility_z_threshold": {
          "default": 1.5,
          "title": "Volatility Z Threshold",
          "type": "number"
        },
        "ai_confidence_threshold": {
          "default": 0.5,
          "title": "Ai Confidence Threshold",
          "type": "number"
        },
        "bem_min_handlers": {
          "default": 3,
          "title": "Bem Min Handlers",
          "type": "integer"
        },
        "tpd_min_test_functions": {
          "default": 5,
          "title": "Tpd Min Test Functions",
          "type": "integer"
        },
        "tpd_min_assertions_per_test": {
          "default": 1,
          "title": "Tpd Min Assertions Per Test",
          "type": "integer"
        },
        "gcd_min_public_functions": {
          "default": 3,
          "title": "Gcd Min Public Functions",
          "type": "integer"
        },
        "gcd_max_nesting_depth": {
          "default": 4,
          "title": "Gcd Max Nesting Depth",
          "type": "integer"
        },
        "nbv_min_function_loc": {
          "default": 3,
          "title": "Nbv Min Function Loc",
          "type": "integer"
        },
        "bat_density_threshold": {
          "default": 0.05,
          "title": "Bat Density Threshold",
          "type": "number"
        },
        "bat_min_loc": {
          "default": 50,
          "title": "Bat Min Loc",
          "type": "integer"
        },
        "ecm_max_files": {
          "default": 50,
          "title": "Ecm Max Files",
          "type": "integer"
        },
        "ecm_lookback_commits": {
          "default": 20,
          "title": "Ecm Lookback Commits",
          "type": "integer"
        },
        "cxs_max_complexity": {
          "default": 15,
          "title": "Cxs Max Complexity",
          "type": "integer"
        },
        "foe_max_imports": {
          "default": 15,
          "title": "Foe Max Imports",
          "type": "integer"
        },
        "dca_ignore_re_exports": {
          "default": true,
          "title": "Dca Ignore Re Exports",
          "type": "boolean"
        },
        "max_discovery_files": {
          "default": 10000,
          "title": "Max Discovery Files",
          "type": "integer"
        },
        "small_repo_module_threshold": {
          "default": 15,
          "title": "Small Repo Module Threshold",
          "type": "integer"
        },
        "small_repo_min_findings": {
          "default": 2,
          "title": "Small Repo Min Findings",
          "type": "integer"
        },
        "diff_baseline_recommend_max_changed_files": {
          "default": 50,
          "title": "Diff Baseline Recommend Max Changed Files",
          "type": "integer"
        },
        "diff_baseline_recommend_max_new_findings": {
          "default": 100,
          "title": "Diff Baseline Recommend Max New Findings",
          "type": "integer"
        },
        "diff_baseline_recommend_max_out_of_scope_findings": {
          "default": 50,
          "title": "Diff Baseline Recommend Max Out Of Scope Findings",
          "type": "integer"
        },
        "phr_runtime_validation": {
          "default": false,
          "title": "Phr Runtime Validation",
          "type": "boolean"
        },
        "hsc_min_entropy": {
          "default": 3.5,
          "title": "Hsc Min Entropy",
          "type": "number"
        },
        "hsc_min_length": {
          "default": 16,
          "title": "Hsc Min Length",
          "type": "integer"
        },
        "maz_public_endpoint_allowlist": {
          "items": {
            "type": "string"
          },
          "title": "Maz Public Endpoint Allowlist",
          "type": "array"
        },
        "maz_dev_tool_paths": {
          "items": {
            "type": "string"
          },
          "title": "Maz Dev Tool Paths",
          "type": "array"
        }
      },
      "title": "ThresholdsConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Main drift configuration, loaded from drift.yaml.",
  "properties": {
    "extends": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Name of a built-in preset to inherit from (e.g. 'vibe-coding', 'strict', 'fastapi', 'library', 'monorepo'). User-level fields override preset defaults.",
      "title": "Extends"
    },
    "include": {
      "items": {
        "type": "string"
      },
      "title": "Include",
      "type": "array"
    },
    "exclude": {
      "items": {
        "type": "string"
      },
      "title": "Exclude",
      "type": "array"
    },
    "policies": {
      "$ref": "#/$defs/PolicyConfig"
    },
    "weights": {
      "$ref": "#/$defs/SignalWeights"
    },
    "thresholds": {
      "$ref": "#/$defs/ThresholdsConfig"
    },
    "cache_dir": {
      "default": ".drift-cache",
      "title": "Cache Dir",
      "type": "string"
    },
    "test_file_handling": {
