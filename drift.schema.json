{
  "$defs": {
    "BriefConfig": {
      "additionalProperties": false,
      "description": "Configuration for ``drift brief`` pre-task briefings.",
      "properties": {
        "scope_aliases": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Keyword → path mapping for scope resolution. Example: {payment: src/billing/, auth: src/auth/}",
          "title": "Scope Aliases",
          "type": "object"
        }
      },
      "title": "BriefConfig",
      "type": "object"
    },
    "DeferredArea": {
      "additionalProperties": false,
      "description": "A glob-matched area marked as known technical debt (not excluded).\n\nUnlike ``exclude``, deferred areas are still analysed.  Findings in\ndeferred areas are tagged ``deferred=True`` so CI gates and reports\ncan treat them differently.",
      "properties": {
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "reason": {
          "default": "",
          "title": "Reason",
          "type": "string"
        },
        "review_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review By"
        }
      },
      "required": [
        "pattern"
      ],
      "title": "DeferredArea",
      "type": "object"
    },
    "FindingContextPolicy": {
      "additionalProperties": false,
      "description": "Policy for finding-context classification and triage behavior.",
      "properties": {
        "rules": {
          "items": {
            "$ref": "#/$defs/FindingContextRule"
          },
          "title": "Rules",
          "type": "array"
        },
        "non_operational_contexts": {
          "items": {
            "type": "string"
          },
          "title": "Non Operational Contexts",
          "type": "array"
        },
        "default_context": {
          "default": "production",
          "title": "Default Context",
          "type": "string"
        }
      },
      "title": "FindingContextPolicy",
      "type": "object"
    },
    "FindingContextRule": {
      "additionalProperties": false,
      "description": "Classify findings by file path using glob patterns.",
      "properties": {
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "context": {
          "title": "Context",
          "type": "string"
        },
        "precedence": {
          "default": 0,
          "title": "Precedence",
          "type": "integer"
        }
      },
      "required": [
        "pattern",
        "context"
      ],
      "title": "FindingContextRule",
      "type": "object"
    },
    "LayerBoundary": {
      "additionalProperties": false,
      "description": "A single layer boundary rule.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "from": {
          "title": "From",
          "type": "string"
        },
        "deny_import": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Deny Import",
          "type": "array"
        }
      },
      "required": [
        "name",
        "from"
      ],
      "title": "LayerBoundary",
      "type": "object"
    },
    "LazyImportRule": {
      "additionalProperties": false,
      "description": "Policy rule for enforcing lazy imports of selected modules.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "from": {
          "title": "From",
          "type": "string"
        },
        "modules": {
          "items": {
            "type": "string"
          },
          "title": "Modules",
          "type": "array"
        },
        "module_level_only": {
          "default": true,
          "title": "Module Level Only",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "from"
      ],
      "title": "LazyImportRule",
      "type": "object"
    },
    "PathOverride": {
      "additionalProperties": false,
      "description": "Per-path configuration overrides.\n\nMatch paths using glob patterns (e.g. ``tests/**``, ``legacy/``).\nMore specific patterns take precedence over broader ones.",
      "properties": {
        "weights": {
          "anyOf": [
            {
              "$ref": "#/$defs/SignalWeights"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "exclude_signals": {
          "items": {
            "type": "string"
          },
          "title": "Exclude Signals",
          "type": "array"
        },
        "severity_gate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Severity Gate"
        }
      },
      "title": "PathOverride",
      "type": "object"
    },
    "PluginConfig": {
      "additionalProperties": false,
      "description": "Configuration for Drift plugins.\n\nPlugins are discovered via Python entry_points (see drift.plugins).\nThis configuration section allows selectively disabling specific plugins.\n\nExample drift.yaml::\n\n    plugins:\n      disabled:\n        - my_broken_plugin",
      "properties": {
        "disabled": {
          "description": "List of plugin entry-point names to skip at discovery time.",
          "items": {
            "type": "string"
          },
          "title": "Disabled",
          "type": "array"
        }
      },
      "title": "PluginConfig",
      "type": "object"
    },
    "PolicyConfig": {
      "additionalProperties": false,
      "description": "Policy configuration for enforcement rules.",
      "properties": {
        "error_handling": {
          "additionalProperties": true,
          "title": "Error Handling",
          "type": "object"
        },
        "layer_boundaries": {
          "items": {
            "$ref": "#/$defs/LayerBoundary"
          },
          "title": "Layer Boundaries",
          "type": "array"
        },
        "max_pattern_variants": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Max Pattern Variants",
          "type": "object"
        },
        "ai_attribution": {
          "additionalProperties": true,
          "title": "Ai Attribution",
          "type": "object"
        },
        "allowed_cross_layer": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Cross Layer",
          "type": "array"
        },
        "lazy_import_rules": {
          "items": {
            "$ref": "#/$defs/LazyImportRule"
          },
          "title": "Lazy Import Rules",
          "type": "array"
        }
      },
      "title": "PolicyConfig",
      "type": "object"
    },
    "SignalWeights": {
      "additionalProperties": true,
      "description": "Weights for each detection signal in composite scoring.\n\nWeights are normalised internally — they don't need to sum to 1.0,\nbut a warning is emitted if they deviate significantly.\n\nSignals can be run in report-only mode by assigning weight 0.0.\nThis keeps detection visible while removing score impact until\nprecision/recall is sufficiently validated.",
      "properties": {
        "pattern_fragmentation": {
          "default": 0.16,
          "title": "Pattern Fragmentation",
          "type": "number"
        },
        "architecture_violation": {
          "default": 0.16,
          "title": "Architecture Violation",
          "type": "number"
        },
        "mutant_duplicate": {
          "default": 0.13,
          "title": "Mutant Duplicate",
          "type": "number"
        },
        "explainability_deficit": {
          "default": 0.09,
          "title": "Explainability Deficit",
          "type": "number"
        },
        "temporal_volatility": {
          "default": 0.0,
          "title": "Temporal Volatility",
          "type": "number"
        },
        "system_misalignment": {
          "default": 0.08,
          "title": "System Misalignment",
          "type": "number"
        },
        "doc_impl_drift": {
          "default": 0.04,
          "title": "Doc Impl Drift",
          "type": "number"
        },
        "broad_exception_monoculture": {
          "default": 0.04,
          "title": "Broad Exception Monoculture",
          "type": "number"
        },
        "test_polarity_deficit": {
          "default": 0.04,
          "title": "Test Polarity Deficit",
          "type": "number"
        },
        "guard_clause_deficit": {
          "default": 0.03,
          "title": "Guard Clause Deficit",
          "type": "number"
        },
        "cohesion_deficit": {
          "default": 0.01,
          "title": "Cohesion Deficit",
          "type": "number"
        },
        "naming_contract_violation": {
          "default": 0.04,
          "title": "Naming Contract Violation",
          "type": "number"
        },
        "bypass_accumulation": {
          "default": 0.03,
          "title": "Bypass Accumulation",
          "type": "number"
        },
        "exception_contract_drift": {
          "default": 0.03,
          "title": "Exception Contract Drift",
          "type": "number"
        },
        "co_change_coupling": {
          "default": 0.005,
          "title": "Co Change Coupling",
          "type": "number"
        },
        "ts_architecture": {
          "default": 0.0,
          "title": "Ts Architecture",
          "type": "number"
        },
        "cognitive_complexity": {
          "default": 0.0,
          "title": "Cognitive Complexity",
          "type": "number"
        },
        "fan_out_explosion": {
          "default": 0.0,
          "title": "Fan Out Explosion",
          "type": "number"
        },
        "circular_import": {
          "default": 0.0,
          "title": "Circular Import",
          "type": "number"
        },
        "dead_code_accumulation": {
          "default": 0.0,
          "title": "Dead Code Accumulation",
          "type": "number"
        },
        "missing_authorization": {
          "default": 0.0,
          "title": "Missing Authorization",
          "type": "number"
        },
        "insecure_default": {
          "default": 0.0,
          "title": "Insecure Default",
          "type": "number"
        },
        "hardcoded_secret": {
          "default": 0.0,
          "title": "Hardcoded Secret",
          "type": "number"
        }
      },
      "title": "SignalWeights",
      "type": "object"
    },
    "ThresholdsConfig": {
      "additionalProperties": false,
      "description": "Tunable thresholds for detection signals.",
      "properties": {
        "high_complexity": {
          "default": 10,
          "title": "High Complexity",
          "type": "integer"
        },
        "medium_complexity": {
          "default": 5,
          "title": "Medium Complexity",
          "type": "integer"
        },
        "min_function_loc": {
          "default": 10,
          "title": "Min Function Loc",
          "type": "integer"
        },
        "min_complexity": {
          "default": 5,
          "title": "Min Complexity",
          "type": "integer"
        },
        "similarity_threshold": {
          "default": 0.8,
          "title": "Similarity Threshold",
          "type": "number"
        },
        "recency_days": {
          "default": 14,
          "title": "Recency Days",
          "type": "integer"
        },
        "volatility_z_threshold": {
          "default": 1.5,
          "title": "Volatility Z Threshold",
          "type": "number"
        },
        "ai_confidence_threshold": {
          "default": 0.5,
          "title": "Ai Confidence Threshold",
          "type": "number"
        },
        "bem_min_handlers": {
          "default": 3,
          "title": "Bem Min Handlers",
          "type": "integer"
        },
        "tpd_min_test_functions": {
          "default": 5,
          "title": "Tpd Min Test Functions",
          "type": "integer"
        },
        "tpd_min_assertions_per_test": {
          "default": 1,
          "title": "Tpd Min Assertions Per Test",
          "type": "integer"
        },
        "gcd_min_public_functions": {
          "default": 3,
          "title": "Gcd Min Public Functions",
          "type": "integer"
        },
        "gcd_max_nesting_depth": {
          "default": 4,
          "title": "Gcd Max Nesting Depth",
          "type": "integer"
        },
        "nbv_min_function_loc": {
          "default": 3,
          "title": "Nbv Min Function Loc",
          "type": "integer"
        },
        "bat_density_threshold": {
          "default": 0.05,
          "title": "Bat Density Threshold",
          "type": "number"
        },
        "bat_min_loc": {
          "default": 50,
          "title": "Bat Min Loc",
          "type": "integer"
        },
        "ecm_max_files": {
          "default": 50,
          "title": "Ecm Max Files",
          "type": "integer"
        },
        "ecm_lookback_commits": {
          "default": 20,
          "title": "Ecm Lookback Commits",
          "type": "integer"
        },
        "cxs_max_complexity": {
          "default": 15,
          "title": "Cxs Max Complexity",
          "type": "integer"
        },
        "foe_max_imports": {
          "default": 15,
          "title": "Foe Max Imports",
          "type": "integer"
        },
        "dca_ignore_re_exports": {
          "default": true,
          "title": "Dca Ignore Re Exports",
          "type": "boolean"
        },
        "max_discovery_files": {
          "default": 10000,
          "title": "Max Discovery Files",
          "type": "integer"
        },
        "small_repo_module_threshold": {
          "default": 15,
          "title": "Small Repo Module Threshold",
          "type": "integer"
        },
        "small_repo_min_findings": {
          "default": 2,
          "title": "Small Repo Min Findings",
          "type": "integer"
        },
        "diff_baseline_recommend_max_changed_files": {
          "default": 50,
          "title": "Diff Baseline Recommend Max Changed Files",
          "type": "integer"
        },
        "diff_baseline_recommend_max_new_findings": {
          "default": 100,
          "title": "Diff Baseline Recommend Max New Findings",
          "type": "integer"
        },
        "diff_baseline_recommend_max_out_of_scope_findings": {
          "default": 50,
          "title": "Diff Baseline Recommend Max Out Of Scope Findings",
          "type": "integer"
        },
        "hsc_min_entropy": {
          "default": 3.5,
          "title": "Hsc Min Entropy",
          "type": "number"
        },
        "hsc_min_length": {
          "default": 16,
          "title": "Hsc Min Length",
          "type": "integer"
        },
        "maz_public_endpoint_allowlist": {
          "items": {
            "type": "string"
          },
          "title": "Maz Public Endpoint Allowlist",
          "type": "array"
        },
        "maz_dev_tool_paths": {
          "items": {
            "type": "string"
          },
          "title": "Maz Dev Tool Paths",
          "type": "array"
        }
      },
      "title": "ThresholdsConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Main drift configuration, loaded from drift.yaml.",
  "properties": {
    "include": {
      "items": {
        "type": "string"
      },
      "title": "Include",
      "type": "array"
    },
    "exclude": {
      "items": {
        "type": "string"
      },
      "title": "Exclude",
      "type": "array"
    },
    "policies": {
      "$ref": "#/$defs/PolicyConfig"
    },
    "weights": {
      "$ref": "#/$defs/SignalWeights"
    },
    "thresholds": {
      "$ref": "#/$defs/ThresholdsConfig"
    },
    "cache_dir": {
      "default": ".drift-cache",
      "title": "Cache Dir",
      "type": "string"
    },
    "fail_on": {
      "default": "high",
      "title": "Fail On",
      "type": "string"
    },
    "context_dampening": {
      "default": 0.5,
      "title": "Context Dampening",
      "type": "number"
    },
    "fail_on_delta": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fail On Delta"
    },
    "fail_on_delta_window": {
      "default": 5,
      "title": "Fail On Delta Window",
      "type": "integer"
    },
    "auto_calibrate": {
      "default": true,
      "title": "Auto Calibrate",
      "type": "boolean"
    },
    "embeddings_enabled": {
      "default": true,
      "title": "Embeddings Enabled",
      "type": "boolean"
    },
    "embedding_model": {
      "default": "all-MiniLM-L6-v2",
      "title": "Embedding Model",
      "type": "string"
    },
    "embedding_batch_size": {
      "default": 64,
      "title": "Embedding Batch Size",
      "type": "integer"
    },
    "path_overrides": {
      "additionalProperties": {
        "$ref": "#/$defs/PathOverride"
      },
      "title": "Path Overrides",
      "type": "object"
    },
    "deferred": {
      "items": {
        "$ref": "#/$defs/DeferredArea"
      },
      "title": "Deferred",
      "type": "array"
    },
    "finding_context": {
      "$ref": "#/$defs/FindingContextPolicy"
    },
    "brief": {
      "$ref": "#/$defs/BriefConfig"
    },
    "plugins": {
      "$ref": "#/$defs/PluginConfig"
    }
  },
  "title": "DriftConfig",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
